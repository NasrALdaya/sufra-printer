{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sufra Printer",
  "identifier": "app.sufra.printer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sufra Printer",
        "width": 480,
        "height": 640,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "visible": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Silent ESC/POS thermal printer bridge for Sufra dashboard",
    "longDescription": "Companion app that exposes a localhost HTTP endpoint for the Sufra POS dashboard to print receipts and kitchen tickets silently in the background. Works fully offline."
  }
}
